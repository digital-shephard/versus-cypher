# Versus production / testnet deploy
#
# REQUIRED for baseSepolia / base:
#   PROTOCOL_RECIPIENT = your immutable deployed Safe/vault contract (receives 10% of every tranche)
#   PRIVATE_KEY        = deployer key (only used to deploy + one-shot bootstrap — holds no admin after)

PRIVATE_KEY=
# Production Safe on Base: 0x93645ce5BCF0009026D8100aea5901cDd52217bF
# See docs/PRODUCTION_FREEZE.md
PROTOCOL_RECIPIENT=

# RPCs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=

# Testnet/local overrides only (Base mainnet rejects a floor override)
# GRADUATION_FLOOR_USDC=1000
# USE_MOCK_USDC=true          # baseSepolia only — deploy MockUSDC instead of canonical USDC

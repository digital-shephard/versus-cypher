# Versus production / testnet deploy
#
# REQUIRED for baseSepolia / base:
#   PROTOCOL_RECIPIENT = your immutable dev vault (receives 10% of every finalized tranche)
#   PRIVATE_KEY        = deployer key (only used to deploy + one-shot bootstrap — holds no admin after)

PRIVATE_KEY=
PROTOCOL_RECIPIENT=

# RPCs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=

# Optional overrides (defaults are production values)
# GRADUATION_FLOOR_USDC=1000
# USE_MOCK_USDC=true          # baseSepolia only — deploy MockUSDC instead of canonical USDC

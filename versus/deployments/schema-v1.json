{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://versus.network/schemas/deployment-manifest-v1.json",
  "title": "Versus Cypher deployment manifest v1",
  "type": "object",
  "required": [
    "manifestVersion", "protocol", "network", "chainId", "releaseStage", "source",
    "compiler", "economics", "dependencies", "contracts", "constructorArguments",
    "transactions", "runtimeBytecode", "verification", "deployedAt"
  ],
  "properties": {
    "manifestVersion": { "const": 1 },
    "protocol": { "const": "versus-cypher" },
    "network": { "type": "string" },
    "rainAttestors": {
      "type": "array",
      "items": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
      "uniqueItems": true,
      "minItems": 1
    },
    "chainId": { "type": "integer" },
    "releaseStage": { "enum": ["test", "closed-cohort", "unrestricted-public"] },
    "source": {
      "type": "object",
      "required": ["repository", "commit", "clean", "treeSha256", "files"],
      "properties": {
        "repository": { "type": "string" },
        "commit": { "type": "string", "pattern": "^[a-fA-F0-9]{40}$" },
        "clean": { "type": "boolean" },
        "treeSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "files": { "type": "array" }
      }
    },
    "contracts": { "type": "object" },
    "constructorArguments": { "type": "object" },
    "runtimeBytecode": { "type": "object" },
    "verification": { "type": "object" }
  },
  "additionalProperties": true
}
